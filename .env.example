# Database
DATABASE_URL="postgresql://nextworth:nextworth@localhost:5436/nextworth"

# BetterAuth
BETTER_AUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ML Service
ML_SERVICE_URL="http://localhost:5000"

# Google Gemini (Advisor chat) - get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""

# logo.dev (asset logos) - get keys at https://logo.dev
# Public token goes in the <img> src; secret key is reserved for server-side APIs.
NEXT_PUBLIC_LOGO_DEV_TOKEN=""
LOGO_DEV_SECRET_KEY=""

# Resend (password-reset emails) - get a key at https://resend.com/api-keys
# Optional: when unset, reset links are logged to the server console instead of emailed.
# EMAIL_FROM needs a verified domain in production (e.g. "NextWorth <no-reply@yourdomain.com>").
RESEND_API_KEY=""
EMAIL_FROM=""
